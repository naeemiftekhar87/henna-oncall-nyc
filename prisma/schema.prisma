generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
}

model Booking {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String
  date      String
  street    String
  apt       String?
  city      String
  state     String
  zip       String
  service   String // "blush", "bloom", "lush", "grace", "petal-feet", "blooming-feet", "regal-steps", "party"
  message   String?
  price     Float
  status    String   @default("pending") // "pending", "confirmed", "completed", "cancelled"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Review {
  id        String   @id @default(cuid())
  name      String
  email     String
  rating    Int // 1-5
  text      String
  service   String?
  approved  Boolean  @default(false)
  source    String   @default("website") // "website" or "google"
  createdAt DateTime @default(now())
}

model Service {
  id        String   @id @default(cuid())
  key       String   @unique // "blush", "bloom", etc.
  name      String
  price     Float
  duration  String
  category  String // "bridal", "feet", "party"
  active    Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SiteConfig {
  id    String @id @default(cuid())
  key   String @unique
  value String
}
